# Database location (optional)
# Default: ./data/freshcrate.db
# Use a persistent mount in production (example: /data/freshcrate.db)
FRESHCRATE_DB_PATH=

# GitHub OAuth App Client ID (for populate pipeline device flow)
# Create one at: https://github.com/settings/applications/new
# No secret needed — device flow uses public clients
FRESHCRATE_GITHUB_CLIENT_ID=

# Or use a personal access token (public repo reads)
GITHUB_TOKEN=

# Contact inbox for /submit human form (server-side email)
HUMAN_CONTACT_EMAIL=

# Resend API key + sender identity for outbound email
RESEND_API_KEY=
FRESHCRATE_CONTACT_FROM=

# Legacy/admin field (optional fallback)
ADMIN_EMAIL=
