# GitHub OAuth App Client ID (for populate pipeline device flow)
# Create one at: https://github.com/settings/applications/new
# No secret needed — device flow uses public clients
FRESHCRATE_GITHUB_CLIENT_ID=

# Or use a personal access token (no scopes needed for public repos)
GITHUB_TOKEN=

# Admin email for submission notifications (submissions are queued, not auto-published)
ADMIN_EMAIL=

# Email service for submission notifications (optional — falls back to console logging)
# Get a free key at https://web3forms.com or use any POST-based email API
EMAIL_API_KEY=
EMAIL_API_ENDPOINT=https://api.web3forms.com/submit
